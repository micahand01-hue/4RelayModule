// ============================================================
// SPI HELPERS
// ============================================================
static inline void csLow()  { digitalWrite(TFT_CS, LOW); }
static inline void csHigh() { digitalWrite(TFT_CS, HIGH); }
static inline void dcCmd()  { digitalWrite(TFT_DC, LOW); }
static inline void dcData() { digitalWrite(TFT_DC, HIGH); }

static void writeCmd(uint8_t cmd) {
  dcCmd();
  csLow();
  tftSPI.transfer(cmd);
  csHigh();
}

static void writeBytes(const uint8_t* data, size_t len) {
  dcData();
  csLow();
  tftSPI.writeBytes(data, len);
  csHigh();
}

static void writeCmdBytes(uint8_t cmd, const uint8_t* data, size_t len) {
  writeCmd(cmd);
  if (len) writeBytes(data, len);
}

